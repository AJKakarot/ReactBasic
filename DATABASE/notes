// ✅ 4. PostgreSQL Queries (Basic)

// 🔹 SELECT
// SELECT * FROM users;
// SELECT name, email FROM users WHERE age > 20;

// 🔹 INSERT
// INSERT INTO users (name, email, age)
// VALUES ('Ajeet', 'ajeet@gmail.com', 22);

// 🔹 UPDATE
// UPDATE users
// SET age = 23
// WHERE email = 'ajeet@gmail.com';

// 🔹 DELETE
// DELETE FROM users
// WHERE email = 'ajeet@gmail.com';


// ✅ 5. Indexing – Kyun use karte hain?
// 🔥 Problem:

// Without index → DB full scan karta hai (slow 😴)

// 🔥 Solution:

// Index → fast search (like book index 📚)

// 🔹 Example (MongoDB)
// userSchema.index({ email: 1 });

// 🔹 Example (SQL)
// CREATE INDEX idx_email ON users(email);

// 💡 Interview Line:

// "Index improves read performance but slightly slows down writes."

// ✅ 6. One-to-Many Relationship (MongoDB)

// 🎯 Example:

// 1 User → many Posts

// 🔹 Option 1: Referencing (Recommended)

// User Schema
// {
//   name: "Ajeet"
// }

// Post Schema
// {
//   title: "Post 1",
//   userId: ObjectId("user_id")
// }

// 🔹 Populate Example
// Post.find().populate("userId");

// 🔹 Option 2: Embedding
// {
//   name: "Ajeet",
//   posts: [
//     { title: "Post 1" },
//     { title: "Post 2" }
//   ]
// }
// 🔥 कब कौन use करें?

// Case	Use
// Large data-> Referencing
// Small + tightly related ->	Embedding
// 💡 Interview Line:

// "Use referencing for scalability, embedding for performance."