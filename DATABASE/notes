// 2. find(), findOne(), findById() – Difference
// 🔹 1. find()
// Multiple documents return karta hai (array)
// const users = await User.find({ age: 20 });

// 👉 Output: [{}, {}, {}]


// 2. findOne()
// Sirf first matching document
// const user = await User.findOne({ email: "test@gmail.com" });

// 👉 Output: {}

// 🔹 3. findById()
// Direct _id se find karta hai (fast & optimized)
// const user = await User.findById("64ab123...");

// 👉 Output: {}



